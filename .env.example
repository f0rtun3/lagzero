LAGZERO_ERROR_WINDOW_SEC=120
LAGZERO_REBALANCE_WINDOW_SEC=90
LAGZERO_INFRA_WINDOW_SEC=300
LAGZERO_MAX_CORRELATIONS=3
LAGZERO_AI_ENABLED=false
LAGZERO_AI_PROVIDER=openai
LAGZERO_AI_MODEL=gpt-5-mini
LAGZERO_AI_MAX_TOKENS=400
LAGZERO_AI_TEMPERATURE=0.1
LAGZERO_AI_CACHE_TTL_SEC=120
LAGZERO_EVENT_LOG_PATH=
