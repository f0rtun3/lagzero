LAGZERO_BOOTSTRAP_SERVERS=localhost:9092
LAGZERO_CONSUMER_GROUP=example-consumer-group
LAGZERO_TOPICS=orders,shipments
LAGZERO_POLL_INTERVAL_SEC=10
LAGZERO_EMITTER=stdout
LAGZERO_LOG_LEVEL=INFO
LAGZERO_LAG_SPIKE_MULTIPLIER=2.0
LAGZERO_MIN_INCIDENT_OFFSET_LAG=25
LAGZERO_MIN_INCIDENT_TIME_LAG_SEC=15
LAGZERO_MIN_STALLED_OFFSET_LAG=50
LAGZERO_MIN_STALLED_TIME_LAG_SEC=30
LAGZERO_MIN_LAG_SPIKE_DELTA=25
LAGZERO_STALLED_INTERVALS=2
LAGZERO_IDLE_INTERVALS=3
LAGZERO_RATE_WINDOW_SIZE=3
LAGZERO_SLOW_CONSUMER_EFFICIENCY_THRESHOLD=0.8
LAGZERO_CATCHING_UP_EFFICIENCY_THRESHOLD=1.0
LAGZERO_BURST_GRACE_SEC=20
LAGZERO_TIMESTAMP_SAMPLE_INTERVAL_SEC=30
LAGZERO_LAG_DIVERGENCE_THRESHOLD_SEC=120
LAGZERO_STATE_TRANSITION_CONFIRMATIONS=2
LAGZERO_CORRELATION_RETENTION_SEC=900
